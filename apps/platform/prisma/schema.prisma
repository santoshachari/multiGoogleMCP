// Multi-tenant Google MCP platform — data model
// Two groups of models:
//   1. Auth.js login models (User, Account, Session, VerificationToken) — how a
//      person signs INTO this platform. `Account` here is a login provider account.
//   2. Domain models (ConnectedAccount, Agent, AgentGrant, ApiKey, AuditLog) — the
//      product itself. `ConnectedAccount` is a Google identity a user links so its
//      Gmail/Calendar/Drive/Chat can be exposed through scoped agents.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// Auth.js (platform login)
// ------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts          Account[]
  sessions          Session[]
  connectedAccounts ConnectedAccount[]
  agents            Agent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------------------
// Domain (the MCP platform)
// ------------------------------------------------------------------

// A Google identity a user has OAuth-linked. Holds the encrypted refresh token
// and the scopes Google actually granted (the ceiling on what any agent can do).
model ConnectedAccount {
  id              String   @id @default(cuid())
  userId          String
  googleEmail     String
  googleSub       String // Google's stable subject id for this identity
  refreshTokenEnc String   @db.Text // AES-256-GCM ciphertext, never plaintext
  grantedScopes   String   @db.Text // space-delimited scope list
  status          String   @default("active") // active | revoked | error
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  grants AgentGrant[]

  @@unique([userId, googleSub])
}

// A named, scoped remote-MCP endpoint owned by a user.
model Agent {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  grants  AgentGrant[]
  apiKeys ApiKey[]
}

// The join: which account an agent may touch, and at what permission per service.
// Permission values: "none" | "readonly" | "full" (gmail also allows "draft").
// The effective permission at call time is min(this grant, the account's OAuth ceiling).
model AgentGrant {
  id                 String @id @default(cuid())
  agentId            String
  connectedAccountId String
  gmail              String @default("none")
  calendar           String @default("none")
  drive              String @default("none")
  chat               String @default("none")

  agent   Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  account ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@unique([agentId, connectedAccountId])
}

// A bearer credential belonging to an agent. Stored only as a hash; shown once.
model ApiKey {
  id         String    @id @default(cuid())
  agentId    String
  name       String?
  keyHash    String    @unique
  prefix     String // short non-secret identifier shown in the UI
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

// Optional record of tool invocations (populated in Phase 5).
model AuditLog {
  id           String   @id @default(cuid())
  apiKeyId     String?
  agentId      String?
  toolName     String
  accountEmail String?
  status       String // ok | denied | error
  createdAt    DateTime @default(now())
}
