# Copy to .env and fill in. Never commit the real .env.

# ---- Database ----
DATABASE_URL="postgresql://USER@localhost:5432/multigmail"

# ---- Auth.js (platform login) ----
# Generate: openssl rand -base64 33
AUTH_SECRET=""
# Web application OAuth client (APIs & Services > Credentials).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---- Secret encryption (Google refresh tokens at rest) ----
# Generate: openssl rand -hex 32  (must be 32 bytes / 64 hex chars)
ENCRYPTION_KEY=""
